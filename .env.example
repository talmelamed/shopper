# --- Telegram ---
# Create a bot with @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# Get yours from @userinfobot. The bot rejects everyone else.
ALLOWED_USER_IDS=

# --- Runtime ---
# local  = headed Chromium on this Mac (you interact with the window directly)
# docker = headed Chromium inside Xvfb, exposed via noVNC on NOVNC_URL
RUN_MODE=local

# Headless is forced false in local mode; this only matters for tests/CI.
HEADLESS=false

# URL the bot tells you to open when login is required (Docker mode).
# Example: http://127.0.0.1:6080/vnc.html
NOVNC_URL=http://127.0.0.1:6080/vnc.html

# Optional password for noVNC (websockify --auth). Strongly recommended if NOVNC_URL is not 127.0.0.1.
NOVNC_PASSWORD=

# --- Storage ---
USER_DATA_DIR=./auth
STATE_DIR=./state
TRACES_DIR=./traces

# --- Shufersal ---
SHUFERSAL_URL=https://www.shufersal.co.il

# --- Pagination ---
RESULTS_PER_PAGE=4
MAX_PAGES=5

# --- Logging ---
# trace | debug | info | warn | error
LOG_LEVEL=info

# --- Shufersal credentials (optional) ---
# When set, the bot logs in automatically on every startup (no /login needed).
# The password is read only from this file — never stored or transmitted elsewhere.
SHUFERSAL_EMAIL=
SHUFERSAL_PASSWORD=

# --- OpenAI (optional) ---
# When OPENAI_API_KEY is empty, the bot falls back to the built-in regex parser
# and shows results in Shufersal's native order. Set the key to enable:
#   1) LLM parsing of free-text / natural-language shopping lists
#   2) LLM re-ranking of search results against the user's intent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
